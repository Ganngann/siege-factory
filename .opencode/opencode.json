{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "Get-ChildItem *": "allow",
      "dir *": "allow",
      "cd *": "allow",
      "Set-Location *": "allow",
      "cat *": "allow",
      "Get-Content *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "Select-String *": "allow",
      "Test-Path *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "cargo check*": "allow",
      "cargo run*": "allow",
      "cargo test*": "allow",
      "cargo fmt*": "allow",
      "cargo doc*": "allow",
      "cargo metadata*": "allow",
      "find *": "allow"
    },
    "edit": "allow"
  },
  "agent": {
    "build": {
      "model": "opencode-go/qwen3.7-max",
      "mode": "primary"
    },
    "plan": {
      "model": "opencode-go/kimi-k2.6",
      "mode": "primary"
    },
    "explore": {
      "model": "opencode-go/mimo-v2.5",
      "mode": "subagent"
    },
    "general": {
      "model": "opencode-go/mimo-v2.5",
      "mode": "subagent"
    }
  }
}
